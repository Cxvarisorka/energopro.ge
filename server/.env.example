PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/energopro
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Seed admin credentials (used by npm run seed)
ADMIN_EMAIL=admin@energopro.ge
ADMIN_PASSWORD=change_me_to_a_strong_password

# Comma-separated email addresses to receive exam reminders
REMINDER_EMAILS=admin@energopro.ge
